# Text/IDE specific metadata
.vscode/
.idea/
*.log
Thumbs.db
.DS_Store

# Infrastructure Secrets (Keep keys out of open source)
license.key
agent.py
CAISY.bat
caisy_engine.sh
CAISY/
main.tf
